# OmniNexus-Oracle Environment Variables
# Copy this file to .env and fill in real values — NEVER commit .env

# ── Helius RPC ─────────────────────────────────────────────────────────────────
HELIUS_API_KEY=your-helius-api-key-here
# Get at: https://dev.helius.xyz

# ── Alchemy ────────────────────────────────────────────────────────────────────
ALCHEMY_API_KEY=your-alchemy-api-key-here
# Get at: https://dashboard.alchemy.com

# ── API Authentication ─────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
RALPH_API_KEY=generate-a-secure-random-32-byte-hex-string
JWT_SECRET=generate-a-secure-random-64-byte-hex-string

# ── Solana ─────────────────────────────────────────────────────────────────────
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=${HELIUS_API_KEY}

# ── EmpireSpawner ──────────────────────────────────────────────────────────────
# Persisted keypair (base58 secret key) — generate once, store securely
SPAWNER_PRIVATE_KEY=

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
