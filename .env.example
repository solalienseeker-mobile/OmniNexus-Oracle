# Copy this to .env and fill values before running.
# Do NOT commit .env with real secrets.

# Supabase Credentials
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Ethereum Credentials
ETH_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
ALCHEMY_API_KEY=your_alchemy_api_key

# Solana Credentials
SOLANA_PRIVATE_KEY=your_solana_keypair_string
SOLANA_SIGNER_ADDRESS=your_solana_signer_address
SOLANA_TREASURY=your_treasury_address
HELIUS_API_KEY=your_helius_api_key
HELIUS_HTTP_URL=https://beta.helius-rpc.com/?api-key=your_helius_api_key

# Biconomy Credentials
BICONOMY_API_KEY=your_biconomy_api_key
BICONOMY_PROJECT_API=your_biconomy_project_api
BICONOMY_PROJECT_ID=your_biconomy_project_id

# Gemini API Key
GEMINI_API_KEY=

# Colosseum Hackathon API Key
COLOSSEUM_API_KEY=

# Ollama settings
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama2

# Optional alerts
MORALIS_API_KEY=your_moralis_api_key
DATABASE_URL=postgres://user:pass@localhost:5432/dbname

